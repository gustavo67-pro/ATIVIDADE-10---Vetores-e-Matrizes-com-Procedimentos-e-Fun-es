programa
{
	funcao inicio()
	{
		inteiro A[2][3] = {
			{1, 2, 3},
			{4, 5, 6}
		}
		inteiro B[3][2] = {
			{7, 8},
			{9, 10},
			{11, 12}
		}
		inteiro R[2][2]

		para (inteiro l = 0; l < 2; l++)
		{
			para (inteiro c = 0; c < 2; c++)
			{
				R[l][c] = (A[l][0] * B[0][c]) + (A[l][1] * B[1][c]) + (A[l][2] * B[2][c])
			}
		}
	}
}
